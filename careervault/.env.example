# SMTP email delivery for password reset OTPs
# Copy this file to .env.local and fill in real provider credentials.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password-or-app-password
SMTP_FROM="CareerVault <no-reply@yourdomain.com>"

# Supabase Postgres persistence
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
DATABASE_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=careervault-documents
