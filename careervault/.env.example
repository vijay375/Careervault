# SMTP email delivery for password reset OTPs
# Brevo API (recommended if SMTP auth fails): https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-account-email
SMTP_PASSWORD=your-brevo-smtp-key

# Use either SMTP_FROM or the pair below (sender must be verified in Brevo):
SMTP_FROM="CareerVault <no-reply@yourdomain.com>"
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=CareerVault

# Supabase Postgres persistence
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=careervault-documents

# Optional: used in password reset emails
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
